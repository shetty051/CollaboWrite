# Database connection strings (Neon or any other Postgres provider)
DATABASE_URL="postgresql://placeholder_user:placeholder_password@placeholder_host/placeholder_db?sslmode=require&pgbouncer=true"
DIRECT_URL="postgresql://placeholder_user:placeholder_password@placeholder_host/placeholder_db?sslmode=require"

# NextAuth Configuration
# Run `openssl rand -base64 32` or use a secure generator for this secret
NEXTAUTH_SECRET="your_super_secret_placeholder_string"
NEXTAUTH_URL="https://your-production-url.com"
